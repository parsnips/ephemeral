# Copy to .env and fill in. docker-compose reads it automatically.

# AWS region for STS. Decoupled from the Twisp host; set this to wherever your
# AWS principal lives (or leave at us-east-1 — STS works regionally and the
# JWT issuer is global, so the same client registration covers all regions).
AWS_REGION=us-east-1

# AWS credentials. Easiest path is an SSO profile mounted from ~/.aws.
AWS_PROFILE=cloud-rw

# accountId of the parent "vend" tenant created in your Twisp org. Must exist
# in whichever Twisp host you point at below.
VEND_ACCOUNT_ID=ephemeral-vend

# Twisp host to talk to. Examples:
#   api.us-east-1.cloud.twisp.com   (default)
#   api.us-west-2.cloud.twisp.com
#   api.us-east-1.dev.twisp.com
# gRPC is the same host on :50051 — only set the hostname here.
TWISP_HOST=api.us-east-1.cloud.twisp.com

# JWT audience claim. Whatever you assert against in the client policy.
AUDIENCE=ephemeral

# Prefix for ephemeral tenant accountIds (a 12-char suffix is appended).
EPHEMERAL_PREFIX=ephemeral

# Bootstrap auth client on the freshly-created ephemeral tenant.
# Find your STS issuer once: `aws sts get-web-identity-token --audience ephemeral --signing-algorithm RS256` and
# decode the JWT — `iss` is what you put here. Same value works across all your AWS accounts as long as the AWS
# account is the same.
# CLIENT_PRINCIPAL=https://aaaaaaaa-bbbb-cccc-dddd-eeeeeeeeeeee.tokens.sts.global.api.aws
# CLIENT_POLICY=./policy.example.json
